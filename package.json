{
  "name": "core-tail",
  "version": "26.02.24",
  "description": "Cloudflare Workers tail event aggregator with AI-powered log analysis",
  "license": "MIT",
  "author": {
    "name": "jmbish04",
    "url": "https://github.com/jmbish04"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmbish04/core-tail"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "rm -rf dist .astro node_modules/.vite",
    "build": "astro build",
    "preview": "wrangler dev",
    "start": "astro dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "check": "oxlint && oxfmt",
    "db:generate": "drizzle-kit generate",
    "migrate:local": "npx wrangler d1 migrations apply DB --local",
    "migrate:remote": "npx wrangler d1 migrations apply DB --remote",
    "deploy": "pnpm run build && node build-worker.js && cp .assetsignore dist/.assetsignore && pnpm run migrate:remote && npx wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@assistant-ui/react": "^0.12.26",
    "@assistant-ui/react-ai-sdk": "^1.3.20",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/react": "^4.4.2",
    "@base-ui/react": "^1.4.1",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "@hono/zod-validator": "^0.7.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@scalar/hono-api-reference": "^0.10.5",
    "@tailwindcss/vite": "^4.2.1",
    "@udecode/plate-basic-elements": "^48.0.0",
    "@udecode/plate-basic-marks": "^48.0.0",
    "@udecode/plate-common": "^41.0.13",
    "@udecode/plate-core": "^48.0.5",
    "agents": "^0.1.3",
    "ai": "^6.0.138",
    "astro": "^5.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.15",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.1",
    "shadcn": "^4.0.0",
    "slate": "^0.124.0",
    "slate-history": "^0.113.1",
    "slate-react": "^0.124.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.77.0"
  }
}
