---
import { cn } from "@/lib/utils";

import HeadSEO from "@/components/HeadSEO.astro";
import { Header } from "@/components/Header";
import { Footer } from "@/components/Footer";
import { GlobalToaster } from "@/components/GlobalToaster";

import { getWorkerApiKey } from "../../backend/utils/secrets";

const { title, description, ogImage } = Astro.props;
const env = Astro.locals?.runtime?.env || ({} as any);
const resolvedApiKey = await getWorkerApiKey(env) || "";
---

<!doctype html>
<html lang="en">
  <head>
    <HeadSEO title={title} description={description} ogImage={ogImage} />
    <script is:inline define:vars={{ apiKey: resolvedApiKey }}>
      (() => {
        try {
          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          const dark = stored ? stored === "dark" : prefersDark;
          document.documentElement.classList.toggle("dark", dark);
        } catch (e) {}

        if (apiKey) {
          window.WORKER_API_KEY = apiKey;
          var originalFetch = window.fetch;
          window.fetch = function(url, options) {
            if (typeof url === 'string' && url.startsWith('/api/')) {
              options = options || {};
              if (!options.headers) {
                options.headers = {};
              }
              var authValue = 'Bearer ' + window.WORKER_API_KEY;
              if (options.headers instanceof Headers) {
                if (!options.headers.has('Authorization')) {
                  options.headers.set('Authorization', authValue);
                }
              } else {
                if (!options.headers['Authorization'] && !options.headers['authorization']) {
                  options.headers['Authorization'] = authValue;
                }
              }
            }
            return originalFetch.call(this, url, options);
          };
        }
      })();
    </script>
  </head>
  <body
    class={cn(
      "group/body overscroll-none antialiased [--footer-height:calc(var(--spacing)*14)] [--header-height:calc(var(--spacing)*14)] xl:[--footer-height:calc(var(--spacing)*24)]",
    )}
  >
    <div class="bg-background relative z-10 flex min-h-svh flex-col">
      <Header client:load />
      <main class="flex flex-1 flex-col">
        <slot />
      </main>
      <Footer />
    </div>
    <GlobalToaster client:load />
  </body>
</html>
