---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Core-Tail Logs | Core Tail">
  <div id="core-tail-logs-root"></div>
</BaseLayout>

<script>
  import { CoreTailLogs } from '../components/CoreTailLogs';
  import { ToastProvider } from '../components/ui/toast';
  import { createRoot } from 'react-dom/client';
  import * as React from 'react';

  const container = document.getElementById('core-tail-logs-root');
  if (container) {
    const root = createRoot(container);
    root.render(
      React.createElement(ToastProvider, null,
        React.createElement(CoreTailLogs)
      )
    );
  }
</script>
